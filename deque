#include <iostream>
#include <fstream> // Include the fstream library for file operations

class Deque {
private:
    int* arr;
    int front;
    int rear;
    int capacity;

public:
    Deque(int size) {
        capacity = size;
        arr = new int[capacity];
        front = -1;
        rear = -1;
    }

    ~Deque() {
        delete[] arr;
    }

    bool isEmpty() {
        return front == -1;
    }

    bool isFull() {
        return (front == 0 && rear == capacity - 1) || (front == rear + 1);
    }

    void pushFront(int value) {
        if (isFull()) {
            std::cout << "Deque is full. Cannot push to front." << std::endl;
            return;
        }

        if (isEmpty()) {
            front = rear = 0;
        } else if (front == 0) {
            front = capacity - 1;
        } else {
            front--;
        }

        arr[front] = value;
    }

    void pushRear(int value) {
        if (isFull()) {
            std::cout << "Deque is full. Cannot push to rear." << std::endl;
            return;
        }

        if (isEmpty()) {
            front = rear = 0;
        } else if (rear == capacity - 1) {
            rear = 0;
        } else {
            rear++;
        }

        arr[rear] = value;
    }

    int popFront() {
        if (isEmpty()) {
            std::cout << "Deque is empty. Cannot pop from front." << std::endl;
            return -1;
        }

        int value = arr[front];

        if (front == rear) {
            front = rear = -1;
        } else if (front == capacity - 1) {
            front = 0;
        } else {
            front++;
        }

        return value;
    }

    int popRear() {
        if (isEmpty()) {
            std::cout << "Deque is empty. Cannot pop from rear." << std::endl;
            return -1;
        }

        int value = arr[rear];

        if (front == rear) {
            front = rear = -1;
        } else if (rear == 0) {
            rear = capacity - 1;
        } else {
            rear--;
        }

        return value;
    }
};

int main() {
    Deque deque(5);

    deque.pushFront(1);
    deque.pushRear(2);
    deque.pushFront(3);
    deque.pushRear(4);

    std::cout << "Front element: " << deque.popFront() << std::endl;
    std::cout << "Rear element: " << deque.popRear() << std::endl;


    std::ofstream outputFile("output1.txt");
    if (outputFile.is_open()) {
        outputFile << "Front element: " << deque.popFront() << std::endl;
        outputFile << "Rear element: " << deque.popRear() << std::endl;
        outputFile.close();
        std::cout << "Data has been written to 'output1.txt'." << std::endl;
    } else {
        std::cout << "Unable to open 'output1.txt' for writing." << std::endl;
    }

    return 0;
}
